# Override OAuth/Auth server base URL (default: https://llama.voracious.se)
# LLAMA_AUTH_SERVER_BASE_URL=https://llama.voracious.se

# Optional request tuning
# LLAMA_AUTH_SERVER_TIMEOUT_MS=8000
# LLAMA_AUTH_SERVER_MAX_RETRIES=1

# Optional explicit env file path
# LLAMA_ENV_FILE=/absolute/path/to/.env

# Optional SQLite DB path override
# LLAMA_DB_PATH=/absolute/path/to/llamamail.db

# Debug/dev flags (disabled by default)
# Set to 1 to bypass single-instance lock
# LLAMA_ALLOW_MULTI_INSTANCE=0

# Set to 1 to allow standalone cloud OAuth (normally disabled to enforce account-token reuse)
# LLAMA_ALLOW_STANDALONE_CLOUD_OAUTH=0
