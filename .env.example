# Override OAuth/Auth server base URL (default: https://llama.voracious.se)
LUNAMAIL_AUTH_SERVER_BASE_URL=https://llama.voracious.se

# Optional request tuning
LUNAMAIL_AUTH_SERVER_TIMEOUT_MS=8000
LUNAMAIL_AUTH_SERVER_MAX_RETRIES=1

# Optional explicit env file path
# LUNAMAIL_ENV_FILE=/absolute/path/to/.env
