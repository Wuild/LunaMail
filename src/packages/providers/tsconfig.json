{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"lib": ["ES2022", "DOM"],
		"types": ["node"],
		"declaration": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": ["dist", "node_modules"]
}
